# Copy this file to .env and fill in your values
# For local development
MONGODB_URI=mongodb://127.0.0.1:27017/timetable
PORT=5000
JWT_SECRET=your_super_secret_key_here

# For production on Render — set these in the Render dashboard env var settings
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/timetable?retryWrites=true&w=majority
# ALLOWED_ORIGINS=https://your-app.vercel.app
